# ============================================================
# .env.example - 환경 변수 예시
# 이 파일을 복사하여 .env 파일을 만들고 실제 값을 입력하세요
# cp .env.example .env  (또는 install.bat 실행 시 자동 생성)
# ============================================================

# ─────────────────────────────────────────
# 🔐 Google OAuth 2.0 설정
# https://console.cloud.google.com/ 에서 발급
# ─────────────────────────────────────────
GOOGLE_CLIENT_ID=123456789-abcdefghijklmnopqrstuvwxyz.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-abcdefghijklmnopqrstuvwxyz123
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# ─────────────────────────────────────────
# 🔑 JWT 설정
# SECRET_KEY: 최소 32자 이상의 랜덤 문자열
# ─────────────────────────────────────────
SECRET_KEY=your-super-secret-jwt-key-change-this-in-production-min-32chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_DAYS=7

# ─────────────────────────────────────────
# 💳 Polar.sh 결제 설정
# https://polar.sh 에서 발급
# ─────────────────────────────────────────
POLAR_ACCESS_TOKEN=polar_pat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
POLAR_PRODUCT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
POLAR_WEBHOOK_SECRET=your_webhook_secret_from_polar

# ─────────────────────────────────────────
# 🌐 앱 설정
# ─────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
DATABASE_URL=sqlite:///./app.db
FREE_USAGE_LIMIT=5
